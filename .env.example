# Database
DATABASE_URL=postgresql://user:password@localhost:5432/efp

# Redis
REDIS_URL=redis://localhost:6379

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200

# Chain RPCs
PRIMARY_RPC_BASE=https://mainnet.base.org
PRIMARY_RPC_OP=https://mainnet.optimism.io
PRIMARY_RPC_ETH=https://eth.llamarpc.com

# Chain ID (Base = 8453)
CHAIN_ID=8453

# API Configuration
API_PORT=3000
LOG_LEVEL=info

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60000

# Phase Management
SERVE_DURING_SYNC=false
