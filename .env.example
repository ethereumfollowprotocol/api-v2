# Database
DATABASE_URL=postgresql://user:password@localhost:5432/efp

# Redis
REDIS_URL=redis://localhost:6379

# Chain RPCs (use private RPCs for production - public RPCs have rate limits)
PRIMARY_RPC_BASE=https://base-mainnet.g.alchemy.com/v2/YOUR_API_KEY
PRIMARY_RPC_OP=https://opt-mainnet.g.alchemy.com/v2/YOUR_API_KEY
PRIMARY_RPC_ETH=https://eth-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# Chain ID (Base = 8453)
CHAIN_ID=8453

# API Configuration
API_PORT=3000
LOG_LEVEL=info

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60000

# Phase Management
SERVE_DURING_SYNC=false
