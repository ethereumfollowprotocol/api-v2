{
  "name": "efp-api-v2",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "services/*"
  ],
  "scripts": {
    "build": "npm run build --workspace=@efp/shared && npm run build --workspace=@efp/api --workspace=@efp/indexer --workspace=@efp/orchestrator --workspace=@efp/workers --workspace=@efp/wal-listener",
    "dev:api": "dotenv -- tsx watch services/api/src/index.ts",
    "dev:orchestrator": "dotenv -- tsx watch services/orchestrator/src/index.ts",
    "dev:wal-listener": "dotenv -- tsx watch services/wal-listener/src/index.ts",
    "dev:workers": "dotenv -- tsx watch services/workers/src/index.ts",
    "dev:indexer": "dotenv -- tsx watch services/indexer/src/index.ts",
    "start:api": "dotenv -- node services/api/dist/index.js",
    "start:orchestrator": "dotenv -- node services/orchestrator/dist/index.js",
    "start:wal-listener": "dotenv -- node services/wal-listener/dist/index.js",
    "start:workers": "dotenv -- node services/workers/dist/index.js",
    "start:indexer": "dotenv -- node services/indexer/dist/index.js",
    "seed-ens": "dotenv -- node services/indexer/dist/scripts/seed-ens-jobs.js",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:comparison": "vitest run --config vitest.comparison.config.ts",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^8.56.0",
    "prettier": "^3.2.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
