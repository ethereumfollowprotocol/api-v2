{
  "name": "efp-api-v2",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "services/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "dev:api": "npm run dev --workspace=@efp/api",
    "dev:orchestrator": "npm run dev --workspace=@efp/orchestrator",
    "dev:wal-listener": "npm run dev --workspace=@efp/wal-listener",
    "dev:workers": "npm run dev --workspace=@efp/workers",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:comparison": "vitest run --config vitest.comparison.config.ts",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "eslint": "^8.56.0",
    "prettier": "^3.2.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
